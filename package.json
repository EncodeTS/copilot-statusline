{
  "name": "copilot-statusline",
  "version": "0.1.15",
  "description": "A customizable status line formatter for GitHub Copilot CLI — based on ccstatusline",
  "module": "src/copilot-statusline.ts",
  "type": "module",
  "bin": {
    "copilot-statusline": "dist/copilot-statusline.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "bun run src/copilot-statusline.ts",
    "build": "rm -rf dist/* ; bun build src/copilot-statusline.ts --target=node --outfile=dist/copilot-statusline.js --target-version=14 && bun run scripts/generate-launchers.ts",
    "postbuild": "bun run scripts/replace-version.ts",
    "example": "cat scripts/payload.example.json | bun start",
    "prepublishOnly": "bun run build",
    "lint": "bun tsc --noEmit && eslint . --config eslint.config.js --max-warnings=0",
    "lint:fix": "bun tsc --noEmit && eslint . --config eslint.config.js --max-warnings=0 --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@types/bun": "latest",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.1.10",
    "chalk": "^5.5.0",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "ink": "6.2.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.1.1",
    "react-devtools-core": "^7.0.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vitest": "^4.0.18",
    "zod": "^4.0.17"
  },
  "keywords": [
    "copilot",
    "github-copilot",
    "copilot-cli",
    "cli",
    "status-line",
    "statusline",
    "terminal",
    "powerline",
    "developer-tools"
  ],
  "author": "EncodeTS (https://github.com/EncodeTS)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EncodeTS/copilot-statusline.git"
  },
  "homepage": "https://github.com/EncodeTS/copilot-statusline",
  "bugs": {
    "url": "https://github.com/EncodeTS/copilot-statusline/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ],
  "patchedDependencies": {
    "ink@6.2.0": "patches/ink@6.2.0.patch"
  },
  "dependencies": {
    "ink-gradient": "^4.0.0",
    "pluralize": "^8.0.0"
  }
}
